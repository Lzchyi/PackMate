rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'joinedAt']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.joinedAt is number;
    }

    function isValidInventoryItem(data) {
      return data.keys().hasAll(['id', 'uid', 'name', 'category']) &&
             data.id is string &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.category is string;
    }

    function isValidTrip(data) {
      return data.keys().hasAll(['id', 'uid', 'name', 'tripType', 'createdAt']) &&
             data.id is string &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.tripType is string &&
             data.createdAt is number;
    }

    function isValidCustomList(data) {
      return data.keys().hasAll(['id', 'uid', 'name', 'items']) &&
             data.id is string &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.items is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Inventory collection
    match /inventory/{itemId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged() && isValidInventoryItem(request.resource.data);
      allow update: if isDocOwner() && uidNotModified() && isValidInventoryItem(request.resource.data);
      allow delete: if isDocOwner();
    }

    // Trips collection
    match /trips/{tripId} {
      function isParticipant() {
        return isAuthenticated() && request.auth.uid in resource.data.participants;
      }
      
      function isOwnerOrParticipant() {
        return isDocOwner() || isParticipant();
      }

      function isJoining() {
        let isAddingSelf = request.resource.data.participants.hasAll(resource.data.participants) &&
                           request.resource.data.participants.size() == resource.data.participants.size() + 1 &&
                           request.resource.data.participants.hasAny([request.auth.uid]);
        let tokenValid = request.resource.data.lastConsumedToken == resource.data.inviteToken &&
                         !('inviteToken' in request.resource.data);
        let onlyAllowedFields = request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants', 'inviteToken', 'lastConsumedToken', 'participantProfiles']);
        return isAuthenticated() && isAddingSelf && tokenValid && onlyAllowedFields;
      }

      function isParticipantUpdate() {
        let onlyAllowedFields = request.resource.data.diff(resource.data).affectedKeys().hasOnly(['items', 'participants', 'participantProfiles']);
        let isLeaving = request.resource.data.participants.size() == resource.data.participants.size() - 1 &&
                        !request.resource.data.participants.hasAny([request.auth.uid]);
        let participantsUnchanged = request.resource.data.participants == resource.data.participants;
        return isParticipant() && onlyAllowedFields && (isLeaving || participantsUnchanged);
      }

      allow read: if isOwnerOrParticipant() || resource.data.inviteToken != null;
      allow create: if isAuthenticated() && uidUnchanged() && isValidTrip(request.resource.data);
      allow update: if (isDocOwner() && uidNotModified() && isValidTrip(request.resource.data)) || isJoining() || isParticipantUpdate();
      allow delete: if isDocOwner();
    }

    // Custom Lists collection
    match /customLists/{listId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && uidUnchanged() && isValidCustomList(request.resource.data);
      allow update: if isDocOwner() && uidNotModified() && isValidCustomList(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
